<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="wheel" params="name x_reflect y_reflect">
    <link name="${name}_link">
      <visual>
        <xacro:if value="${name == 'right_wheel'}">
          <origin xyz="0.18 0.44 -0.196" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find trailobot_description)/meshes/motor_wheel_2.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="black"/>
        </xacro:if>
        <xacro:if value="${name == 'left_wheel'}">
          <origin xyz="0.18 -0.1 -0.196" rpy="0 0 0"/>
          <geometry>
            <mesh filename="file://$(find trailobot_description)/meshes/motor_wheel_1.stl" scale="0.001 0.001 0.001"/>
          </geometry>
          <material name="black"/>
        </xacro:if>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
          <geometry>
              <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
          </geometry>
      </collision>
      <xacro:wheel_inertia/>
    </link>

    <!-- <link name="${name}_wheel_rotor">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2.0} 0 0"/>
        <geometry>
          <cylinder radius="0.05" length="0.05"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision> -->
      <!-- <xacro:cylinder_inertia m="${mass_wheel}" r="${wheel_radius}" h="${wheel_width}"/> -->
    <!-- </link> -->

    <!-- <joint name="${name}_rotor_joint" type="fixed">
        <origin xyz="${x_reflect*wheel_xoff} ${y_reflect*(base_width/2+wheel_ygap)} ${-wheel_zoff}" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="${name}_wheel_rotor"/>
    </joint> -->

    <joint name="${name}_joint" type="continuous">
      <origin xyz="${x_reflect*wheel_xoff} ${y_reflect*(base_width/2+wheel_ygap)} ${-wheel_zoff}" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <axis xyz="0.0 1.0 0.0"/>
      <dynamics damping="0.7"/>
    </joint>
    <gazebo reference="${name}_link">
        <material>Gazebo/Black</material>
        <mu1>10.0</mu1>
        <mu2>10.0</mu2>
        <kp>100000</kp>
        <kd>10</kd>
        <self_collide>1</self_collide>
    </gazebo>
  </xacro:macro>
</robot>
